# Copy to .env and fill in. The admin app reads these from the environment.
# On Windows, start.bat (in the portable bundle) sources this file on launch.
#
# IMPORTANT: this file is the OPERATOR's credentials — the access key here
# belongs to the `tp-publisher` IAM user, NOT the `tp-dev` user.
# Dev credentials (tp-dev) live in ~/.aws/credentials on the dev machine
# under an AWS profile (default profile name: tp-dev) and must never be
# copied onto an operator laptop.

# S3 bucket the admin publishes view JSONs to. Created by deploy/cloudformation.yaml.
TP_BUCKET=

# AWS region the bucket lives in.
TP_REGION=eu-central-1

# Publisher IAM user credentials (tp-publisher). Create the user's access key
# in the AWS console (IAM → Users → tp-publisher → Security credentials → Create
# access key) after the CloudFormation stack is deployed — the stack creates
# the user + inline publish policy but not the key. The AWS SDK picks these up
# from the environment, so no ~/.aws/credentials file is required on the
# operator's laptop.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: override the path to tournament.json. Defaults to admin/data/tournament.json.
# TP_DATA_FILE=

# Optional: override the admin port. Defaults to 37325.
# PORT=37325
